{
  "name": "xd-cli",
  "version": "0.0.0",
  "license": "MIT",
  "bin": "dist/cli.js",
  "type": "module",
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "build": "bun build ./src/cli.tsx --compile --minify --outfile dist/xd-cli",
