    "react": "^19.2.7"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "chalk": "^5.6.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.8.4",
    "react-devtools-core": "^7.0.1",
    "typescript": "^6.0.3",
    "xo": "^3.0.1"
  }
}
